{
  "name": "sport-king",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "seed": "node scripts/seed-store.mjs",
    "scrape:kaspi": "node scripts/scrape-kaspi-merchant.mjs",
    "scrape:kaspi:full": "node scripts/scrape-kaspi-merchant.mjs --full",
    "cards:premium": "node scripts/generate-premium-cards/generate.mjs",
    "recategorize": "node scripts/category-utils.mjs",
    "qa": "node scripts/qa-smoke.mjs",
    "build": "tsc -b && vite build",
    "start": "node server/index.js",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^5.1.0",
    "lucide-react": "^1.24.0",
    "multer": "^2.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "oxlint": "^1.71.0",
    "puppeteer": "^25.3.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
