# Copy to .env for local development (never commit .env)

# --- Server (runtime) ---
# Required in production (Render dashboard / CLI). Default locally: sportking
ADMIN_PASSWORD=change-me-in-production

# Secret admin URL path (no leading/trailing slash). Default: sk-manage-kz8m2p
ADMIN_PATH=sk-manage-kz8m2p

# Session lifetime in hours
ADMIN_SESSION_HOURS=8

# Brute-force protection for /api/auth/login
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=900000

# HTTP port (Render sets PORT automatically)
PORT=3001

# Persistent data directory (store.json, uploads/, analytics.json)
# Local default: server/data. On Render with disk: /opt/render/project/src/server/data
# DATA_DIR=/opt/render/project/src/server/data

# --- Vite (build time only) ---
# Must match ADMIN_PATH with a leading slash. Rebuild after changing.
VITE_ADMIN_BASE=/sk-manage-kz8m2p
